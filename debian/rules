#!/usr/bin/make -f

%:
	dh $@

VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/-.*//')
BUILD_TIME := $(shell date -u +"%Y-%m-%dT%H:%M:%SZ")
LDFLAGS := -ldflags "-X main.version=$(VERSION) -X main.buildTime=$(BUILD_TIME)"

override_dh_auto_test:
	@echo "Tests skipped during package build"

override_dh_dwz:
	@echo "Skipping dh_dwz for Go binary"

override_dh_auto_configure:
	@echo "Configure not needed for Go"

override_dh_installinit:
	@echo "Skipping dh_installinit (systemd only)"

override_dh_installdeb:
	dh_installdeb
	echo "/etc/default/analytics" > debian/analytics/DEBIAN/conffiles

override_dh_auto_build:
	go build $(LDFLAGS) -o analytics ./cmd/analytics

override_dh_auto_install:
	install -D -m 0755 analytics debian/analytics/usr/bin/analytics

	install -D -m 0644 debian/analytics.service debian/analytics/usr/lib/systemd/system/analytics.service

	install -D -m 0640 debian/analytics.default debian/analytics/etc/default/analytics
	install -D -m 0640 debian/analytics.env debian/analytics/etc/analytics/env.dist
	install -D -m 0644 debian/analytics.logrotate debian/analytics/etc/logrotate.d/analytics

	install -d -m 0750 debian/analytics/var/lib/analytics
	install -d -m 0750 debian/analytics/var/log/analytics

	install -d -m 0755 debian/analytics/usr/share/analytics/dashboard
	cp -r dashboard/dist/* debian/analytics/usr/share/analytics/dashboard/

	install -D -m 0644 analytics.js debian/analytics/usr/share/analytics/analytics.js
	gzip -k -9 -n debian/analytics/usr/share/analytics/analytics.js
	brotli -k -q 11 debian/analytics/usr/share/analytics/analytics.js

override_dh_auto_clean:
	rm -f analytics
	rm -rf debian/analytics
