# Additional environment for analytics service
# This file can be used for secrets that should not be in /etc/default/analytics
# File permissions will be set to 0640 (root:analytics)

# Uncomment and set API keys here if you prefer not to use /etc/default/analytics
#ANALYTICS_API_KEY="your-secret-api-key"
#ANALYTICS_DASHBOARD_API_KEY="your-secret-dashboard-key"
